def setUpConfigFile():
    if getattr(sys, 'frozen', False):
        folder = os.path.dirname(sys.executable)
    else:
        folder = os.path.dirname(os.path.abspath(__file__))
    
    file = os.path.join(folder, "config.txt")

    if not os.path.exists(file):
        config = open(file, "w")
        config.write("Defaultfilepath* \nFontSize* ")
        config.close()

def findDefaultFile():
    if getattr(sys, 'frozen', False):
        folder = os.path.dirname(sys.executable)
    else:
        folder = os.path.dirname(os.path.abspath(__file__))
    file = os.path.join(folder, "config.txt")
    
    config = open(file, "r")
    content = config.read()
    content = content.splitlines()
    defaultFilePath = content[0].split("*")
    if len(defaultFilePath) == 2:
        defaultFilePath = defaultFilePath[1].strip()
        if defaultFilePath != "":
            return defaultFilePath
    
    return None

