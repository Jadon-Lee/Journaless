def is_task(task): # Break down the given line and figure out the month and day. Requires 'task - month day'
    date = task.split('-')
    date.pop(0)
    date[0] = date[0].lstrip().lower().rstrip()
    date = date[0].split(' ')
    if len(date)  == 2:
        if any(key in date[0].split(" ") for key in month_lookup) and date[1].strip().isdigit():
            month = month_lookup.get(date[0], None)
            day = date[1].strip()
            return month, day
    return None, None

def find_pos_in_calendar(task, weeks):
    month, date = is_task(task)
    date = int(date)
    # if the date is in the previous month, it will be in the first line of calendar
    if date > 20 and int(month) == get_previous_month(selected_month) and date in weeks[0]:

        return 0, weeks[0].index(date)
    
    # if date in next month check last two weeks
    elif date < 20 and int(month) == get_next_month(selected_month) and (date in weeks[4] or date in weeks[5]) :
        for i in range(2,len(weeks)):
            week = weeks[i]
            if date in week:
                return i, week.index(date)
    
    # Check current month weeks
    elif int(month) == selected_month:
        for i in range(len(weeks)):
            week = weeks[i]
            if date in week:
                return i, week.index(date)
    return None, None
    
def extract_task(task):
    # Retrieve task from right side of hyphen
    text = task.split('-')
    return text[0].strip()

def update_taskList(event = None):
    # Resets the task list and rebuilds it with all current tasks
    taskList.clear()
    task = textBox.get("1.0", "end-1c")
    task = task.split('\n')

    for i in range(len(task)):
        if "-" in task[i] and task[i] not in taskList and is_task(task[i]) != (None, None):
            taskList.append(task[i])
        
    taskList.sort(key = str.lower)

def add_to_calendar(weeks): 
    
    temp_taskList = taskList.copy() # old task list
    update_taskList() # new TaskList
    
    
    for x in range(len(taskList)):
        text = extract_task(taskList[x])
        task = taskList[x] 

        i, j = find_pos_in_calendar(task, weeks)
        if (i,j) == (None, None):
            #print("Task not in calendar: " + task)
            continue
        else:
            month, day = is_task(task)
            month = int(month)
            if month == selected_month or month == get_previous_month(selected_month) or month == get_next_month(selected_month):
                current_text = str(day_grid[i][j].cget("text"))
                if text not in current_text:
                    day_grid[i][j].config(text = current_text + "\n" + text)

            # for deleting
    oldItems = list(set(temp_taskList) - set(taskList))
    
    for x in range(len(oldItems)):
        temp_newText = []
        text = extract_task(oldItems[x])
        task = oldItems[x]
        
        i, j = find_pos_in_calendar(task, weeks)
        if (i,j) == (None, None):
            continue

        new_text = day_grid[i][j].cget("text").replace(text, "")
        new_text = new_text.splitlines()
        for x in new_text:
            if x != "":
                temp_newText.append(x)
        
        new_text = "\n".join(temp_newText)
        day_grid[i][j].config(text = new_text)
            
