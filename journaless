def get_previous_month(selected_month):
    previous_month = selected_month - 1
    if previous_month < 1:
        previous_month = 12

    return previous_month

def get_next_month(selected_month):
    next_month = selected_month + 1
    if next_month > 12:
        next_month = 1
    return next_month


